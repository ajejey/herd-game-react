{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "herdgame.vercel.app" }],
      "status": 308,
      "headers": { "Location": "https://herdgamesonline.com/$1" }
    },
    {
      "src": "/sitemap\\.xml/?",
      "dest": "/sitemap.xml",
      "headers": { "Content-Type": "application/xml; charset=utf-8" }
    },
    {
      "src": "/robots\\.txt/?",
      "dest": "/robots.txt",
      "headers": { "Content-Type": "text/plain; charset=utf-8" }
    },
    { "handle": "filesystem" },
    {
      "src": "/daily/[^/]+/?",
      "dest": "/daily/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/200.html"
    }
  ]
}
